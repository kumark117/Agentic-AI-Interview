AI_INTERVIEW_MODE=local-full

AI_INTERVIEW_POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_agentic_interview
AI_INTERVIEW_REDIS_DSN=redis://localhost:6379/0
AI_INTERVIEW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# local-full uses real local infra
AI_INTERVIEW_DISABLE_CLEANUP_WORKER=false
