AI_INTERVIEW_MODE=remote

AI_INTERVIEW_POSTGRES_DSN=postgresql+asyncpg://<user>:<password>@<host>:5432/<db_name>
AI_INTERVIEW_REDIS_DSN=redis://<host>:6379/0
# No trailing slashes. Comma-separated. On Render, a variable set on the web service
# overrides the same key from a linked environment group.
AI_INTERVIEW_CORS_ORIGINS=https://<your-frontend>.onrender.com,http://localhost:3000

# remote should keep cleanup worker enabled
AI_INTERVIEW_DISABLE_CLEANUP_WORKER=false
